# Copy this file to passwords.yaml and fill in your values.
# passwords.yaml is gitignored and should never be committed.

development:
  database: 'development_password'
  redis: 'development_password'
  serviceSecret: 'your-service-secret-here'
  adminEmail: 'admin@example.com'
  adminPassword: 'change-me-in-production'
  crdtNodeId: 'postgres-main'
  # Google OAuth (optional)
  # googleClientSecret: '{"web":{"client_id":"...","client_secret":"..."}}'
  # JWT config
  # jwtRefreshTokenPepper: 'your-pepper-here'
  # jwtHmacSha512PrivateKey: 'your-key-here'

test:
  database: 'test_password'
  redis: 'test_password'
  serviceSecret: 'test-service-secret'

staging:
  database: 'change-me'
  redis: 'change-me'
  serviceSecret: 'change-me'

production:
  database: 'change-me'
  redis: 'change-me'
  serviceSecret: 'change-me'
  adminEmail: 'change-me'
  adminPassword: 'change-me'
  # awsAccessKeyId: 'change-me'
  # awsSecretAccessKey: 'change-me'
